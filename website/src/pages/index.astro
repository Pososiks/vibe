---
// Public landing (SSG). Customize copy/branding for your product.
// The CTA points at the webapp; set PUBLIC_WEBAPP_URL at build time on Vercel
// (Project Settings → Environment Variables). Falls back to local dev.
const webappUrl = import.meta.env.PUBLIC_WEBAPP_URL ?? 'http://localhost:5173'
const title = 'Vibe — your SaaS starter'
const description =
  'A full-stack starter: Google sign-in, subscriptions, and a typed data layer on Supabase + Vercel. Clone it and ship.'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body>
		<main>
			<section class="hero" aria-labelledby="page-title">
				<p class="eyebrow">SaaS starter template</p>
				<h1 id="page-title">Ship your product, not your boilerplate.</h1>
				<p class="summary">{description}</p>
				<div class="actions">
					<a class="button" href={webappUrl}>Get started</a>
					<a class="link" href={webappUrl}>Sign in &rarr;</a>
				</div>
				<ul class="features" aria-label="What's included">
					<li><strong>Google sign-in</strong><span>Supabase Auth, no passwords to manage.</span></li>
					<li><strong>Subscriptions</strong><span>creem.io checkout + webhook, synced to your DB.</span></li>
					<li><strong>Supabase + Vercel</strong><span>Postgres, RLS, and edge functions, deployed in minutes.</span></li>
				</ul>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: #f6f8fb;
		color: #14221f;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: #f6f8fb;
	}

	main {
		min-height: 100vh;
		display: grid;
		align-items: center;
		padding: 3rem 1.5rem;
	}

	.hero {
		max-width: 760px;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #4c6f5b;
	}

	h1 {
		margin: 0;
		font-size: 3rem;
		line-height: 1.02;
		letter-spacing: -0.02em;
	}

	.summary {
		margin: 1.5rem 0 0;
		max-width: 580px;
		font-size: 1.125rem;
		line-height: 1.55;
		color: #3e4a42;
	}

	.actions {
		margin: 2rem 0 0;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.button {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		border-radius: 0.625rem;
		background: #14221f;
		color: #f6f8fb;
		font-weight: 600;
		text-decoration: none;
	}

	.button:hover {
		background: #24332e;
	}

	.link {
		color: #4c6f5b;
		font-weight: 600;
		text-decoration: none;
	}

	.link:hover {
		text-decoration: underline;
	}

	.features {
		margin: 3rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 1.25rem;
	}

	.features li {
		display: grid;
		gap: 0.25rem;
	}

	.features strong {
		font-size: 1rem;
	}

	.features span {
		color: #3e4a42;
	}

	@media (min-width: 720px) {
		main {
			padding: 5rem;
		}

		h1 {
			font-size: 4.5rem;
		}

		.summary {
			font-size: 1.25rem;
		}

		.features {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (min-width: 1120px) {
		main {
			padding: 6rem;
		}
	}
</style>
